# Dataverse Web API access (story #5) — copy to .env and fill in.
# .env is git-ignored; never commit real secrets. Production uses Key Vault +
# Managed Identity (Epic 11), not these values.

# Your Dataverse environment URL, e.g. https://org12345.crm.dynamics.com
DATAVERSE_URL=

# Entra ID (Azure AD) app registration used as the Dataverse application user
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Optional: set to 1 to run the Dataverse integration test (creates + deletes a contact)
RUN_DATAVERSE_INTEGRATION=

# Azure OpenAI (story #58). Auth defaults to Entra using the service principal
# above (grant it the "Cognitive Services OpenAI User" role on the resource);
# set AZURE_OPENAI_API_KEY instead for a quick local spike.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
# AZURE_OPENAI_API_KEY=
# Optional: set to 1 to run the Azure OpenAI integration test (one chat + one embed call)
RUN_AI_INTEGRATION=
